{
  "name": "iwli-website",
  "version": "1.0.0",
  "description": "IWLI - AI Waste Automation Platform Marketing Website",
  "main": "index.html",
  "author": "IWLI Team",
  "license": "MIT",
  "homepage": "https://iwli.ai",
  "scripts": {
    "start": "http-server -p 3000 -o -c-1",
    "serve": "http-server -p 8000 -c-1",
    "dev": "http-server . -p 3000 -o",
    "build": "echo 'Static site - no build needed'",
    "lint:html": "echo 'Run: npx html-validator --file index.html'",
    "test": "echo 'Testing not required for static sites'",
    "docker:build": "docker build -t iwli-website .",
    "docker:run": "docker run -p 80:80 -p 443:443 --name iwli-site iwli-website",
    "docker:stop": "docker stop iwli-site && docker rm iwli-site",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "keywords": [
    "waste-management",
    "ai",
    "automation",
    "iot",
    "compliance",
    "environmental",
    "sustainability"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/iwli-website.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/iwli-website/issues",
    "email": "support@iwli.ai"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "devDependencies": {
    "http-server": "^14.1.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "supports css-grid"
  ]
}

