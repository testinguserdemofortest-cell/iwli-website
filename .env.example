# Environment Variables for IWLI Website
# Copy this to .env and fill in your values (NEVER commit this file!)

# ============================================
# GOOGLE ANALYTICS
# ============================================
# Get from: https://analytics.google.com
# Format: G-XXXXXXXXXX (typically)
VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# ============================================
# FORMSPREE (Email Form Handler)
# ============================================
# Get from: https://formspree.io
# Format: f/xxxxxxxx
VITE_FORMSPREE_FORM_ID=f/xxxxxxxx

# ============================================
# WEBSITE CONFIG
# ============================================
VITE_SITE_URL=https://iwli.ai
VITE_SITE_NAME=IWLI
VITE_CONTACT_EMAIL=support@iwli.ai
VITE_PHONE=+1-800-000-0000

# ============================================
# META TAGS & SEO
# ============================================
VITE_META_TITLE=IWLI – AI Waste Automation Platform
VITE_META_DESCRIPTION=Transform industrial waste operations with AI-powered classification, IoT monitoring, route optimization, and automated compliance.
VITE_CANONICAL_URL=https://iwli.ai/

# ============================================
# SOCIAL MEDIA
# ============================================
VITE_TWITTER_HANDLE=@IWLI
VITE_LINKEDIN_URL=https://linkedin.com/company/iwli
VITE_FACEBOOK_PAGE=https://facebook.com/iwli

# ============================================
# DEPLOYMENT
# ============================================
# Options: netlify, vercel, traditional, aws, docker
DEPLOYMENT_PLATFORM=netlify

# For Netlify
NETLIFY_SITE_NAME=your-site-name

# For AWS S3
AWS_BUCKET_NAME=iwli-website-prod
AWS_REGION=us-east-1

# For Docker
DOCKER_REGISTRY=yourusername
DOCKER_IMAGE_TAG=latest

# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV=production
DEBUG=false

# ============================================
# SECURITY
# ============================================
# Never share these publicly!
# For production only
CONTENT_SECURITY_POLICY_ENABLED=true
CORS_ALLOWED_ORIGINS=https://iwli.ai,https://www.iwli.ai
